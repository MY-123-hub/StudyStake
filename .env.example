# StudyStake 部署配置
# 复制此文件为 .env 并填入真实值

# 部署者钱包私钥（不要提交到 Git）
PRIVATE_KEY=0x_your_private_key_here

# USDC 合约地址
# Sepolia 测试网: 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# Mainnet:      0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# 惩罚接收地址
PENALTY_RECEIVER=0x_your_penalty_receiver_address

# RPC URL (可选，也可通过 --rpc-url 传入)
# RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key
